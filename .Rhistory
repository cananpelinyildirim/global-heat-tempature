output$globe <- renderPlotly({
df <- data_pack()
plot_geo(source = "globe") %>%
add_trace(
type = "choropleth",
locations = df$iso_a3,
locationmode = "ISO-3",
z = df$avg_temp,
# ... diğer ayarların ...
zmin = min(df$avg_temp, na.rm = TRUE), # Skalayı verilere göre ayarlar
zmax = max(df$avg_temp, na.rm = TRUE),
marker = list(line = list(color = "rgba(255,255,255,0.45)", width = 0.5))
) %>%
layout(
geo = list(
projection = list(type = "orthographic"),
showland = TRUE,
landcolor = "rgba(255,255,255,0.14)", # Verisi olmayan ülkeler bu renkte görünür (Siyah olmaz)
showocean = TRUE,
oceancolor = "rgba(147, 197, 253, 0.40)", # Senin istediğin açık mavi deniz rengi
bgcolor = "rgba(0,0,0,0)"
)
# ... diğer layout ayarların ...
)
})
runApp()
runApp()
runApp()
